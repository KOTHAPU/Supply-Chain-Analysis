      <column caption='Profit Ratio' datatype='real' default-format='p0.0%' name='[Calculation_485825816108716035]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Calculation_485825816090329088])' />
      </column>
      <column caption='Above Average Sales' datatype='boolean' name='[Calculation_485825816131588101]' role='measure' type='nominal'>
        <calculation class='tableau' formula='SUM([Calculation_485825816090329088])&gt;=WINDOW_AVG(SUM([Calculation_485825816090329088]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_485825816133771270]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / NULLIF(SUM([Revenue]), 0)' />
      </column>
      <column caption='On Time Delivery Flag' datatype='integer' name='[Calculation_485825816134205447]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Shipping_Time] &lt;= [Total_Delivery_Time] THEN 1 ELSE 0 END' />
      </column>
      <column caption='Avg Processing Time (helper)' datatype='real' name='[Calculation_485825816135024648]' role='measure' type='quantitative'>
